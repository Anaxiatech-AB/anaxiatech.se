---
import '../styles/tokens.css';
import '../styles/site.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'sv';
}
const {
  title,
  description = 'Anaxiatech AB βÄî AI-driven defect detection for infrastructure and manufacturing.',
  lang = 'en',
} = Astro.props;

const altLang = lang === 'en' ? 'sv' : 'en';
const altPath = `/${altLang}`;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="canonical" href={new URL(Astro.url.pathname, 'https://anaxiatech.se').href} />
  <link rel="alternate" hreflang="en" href="https://anaxiatech.se/en/" />
  <link rel="alternate" hreflang="sv" href="https://anaxiatech.se/sv/" />
  <link rel="alternate" hreflang="x-default" href="https://anaxiatech.se/en/" />
</head>
<body>
  <nav class="nav">
    <div class="wrap nav__inner">
      <a href={`/${lang}`} class="nav__brand">
        <span class="nav__brand-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
            <path d="M3 4 L11 12 L7 12 L17 21" />
            <path d="M14 3 L21 10" opacity="0.5" />
          </svg>
        </span>
        <span>Anaxiatech<span class="nav__brand-tld">.se</span></span>
      </a>
      <div class="nav__links">
        <a href={`/${lang}#crackz`}>Crackz</a>
        <a href={`/${lang}#consulting`}>{lang === 'en' ? 'Consulting' : 'Konsulting'}</a>
        <a href={`/${lang}#capabilities`}>{lang === 'en' ? 'Services' : 'TjΟΛnster'}</a>
        <a href={`/${lang}#industries`}>{lang === 'en' ? 'Industries' : 'Branscher'}</a>
        <a href={`/${lang}#projects`}>{lang === 'en' ? 'Projects' : 'Projekt'}</a>
        <a href={`/${lang}#about`}>{lang === 'en' ? 'About' : 'Om oss'}</a>
      </div>
      <div class="nav__cta">
        <div class="lang-switcher">
          <a href="/en" class={`lang-switcher__btn${lang === 'en' ? ' lang-switcher__btn--active' : ''}`} data-lang="en">EN</a>
          <span class="lang-switcher__sep">¬Ζ</span>
          <a href="/sv" class={`lang-switcher__btn${lang === 'sv' ? ' lang-switcher__btn--active' : ''}`} data-lang="sv">SV</a>
        </div>
        <button class="nav__hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="2" y1="5" x2="18" y2="5"/>
            <line x1="2" y1="10" x2="18" y2="10"/>
            <line x1="2" y1="15" x2="18" y2="15"/>
          </svg>
        </button>
        <a href={`/${lang}#contact`} class="btn btn--primary">{lang === 'en' ? 'Contact sales' : 'Kontakta oss'}</a>
      </div>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__inner">
      <div class="mobile-menu__header">
        <span class="mobile-menu__title">Menu</span>
        <button class="mobile-menu__close" aria-label="Close menu">&#x2715;</button>
      </div>
      <nav class="mobile-menu__links">
        <a href={`/${lang}#crackz`}>Crackz</a>
        <a href={`/${lang}#consulting`}>{lang === 'en' ? 'Consulting' : 'Konsulting'}</a>
        <a href={`/${lang}#capabilities`}>{lang === 'en' ? 'Services' : 'TjΟΛnster'}</a>
        <a href={`/${lang}#industries`}>{lang === 'en' ? 'Industries' : 'Branscher'}</a>
        <a href={`/${lang}#projects`}>{lang === 'en' ? 'Projects' : 'Projekt'}</a>
        <a href={`/${lang}#about`}>{lang === 'en' ? 'About' : 'Om oss'}</a>
        <a href={`/${lang}#contact`} class="btn btn--primary" style="margin-top: 12px; justify-content: center;">{lang === 'en' ? 'Contact sales' : 'Kontakta oss'}</a>
        <div class="lang-switcher" style="margin-top: 16px; justify-content: center;">
          <a href="/en" class={`lang-switcher__btn${lang === 'en' ? ' lang-switcher__btn--active' : ''}`} data-lang="en">EN</a>
          <span class="lang-switcher__sep">¬Ζ</span>
          <a href="/sv" class={`lang-switcher__btn${lang === 'sv' ? ' lang-switcher__btn--active' : ''}`} data-lang="sv">SV</a>
        </div>
      </nav>
    </div>
  </div>

  <slot />

  <footer class="footer">
    <div class="wrap">
      <div class="footer__top">
        <div>
          <div class="footer__brand">Anaxiatech AB</div>
          <p class="kicker" style="margin-top: 10px; max-width: 38ch;">
            {lang === 'en'
              ? 'Engineering systems that work βÄî above and below the surface. Stockholm-based.'
              : 'Vi bygger system som hΟΞller βÄî ovan och under ytan. Stockholmsbaserade.'}
          </p>
        </div>
        <div class="footer__col">
          <h5>{lang === 'en' ? 'Product' : 'Produkt'}</h5>
          <ul>
            <li><a href={`/${lang}#crackz`}>Crackz</a></li>
            <li><a href={`/${lang}#tour`}>{lang === 'en' ? 'Product tour' : 'ProduktgenomgΟΞng'}</a></li>
            <li><a href={`/${lang}#industries`}>{lang === 'en' ? 'Industries' : 'Branscher'}</a></li>
            <li><a href={`/${lang}#contact`}>{lang === 'en' ? 'Pricing' : 'PrissΟΛttning'}</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h5>{lang === 'en' ? 'Company' : 'FΟΕretag'}</h5>
          <ul>
            <li><a href={`/${lang}#about`}>{lang === 'en' ? 'About' : 'Om oss'}</a></li>
            <li><a href={`/${lang}#projects`}>{lang === 'en' ? 'Projects' : 'Projekt'}</a></li>
            <li><a href={`/${lang}#capabilities`}>{lang === 'en' ? 'Capabilities' : 'Kapacitet'}</a></li>
            <li><a href={`/${lang}#contact`}>{lang === 'en' ? 'Contact' : 'Kontakt'}</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h5>{lang === 'en' ? 'Consulting' : 'Konsulting'}</h5>
          <ul>
            <li><a href={`/${lang}#services`}>{lang === 'en' ? 'Services' : 'TjΟΛnster'}</a></li>
            <li><a href={`/${lang}#engagements`}>{lang === 'en' ? 'Engagements' : 'Uppdragsmodeller'}</a></li>
            <li><a href={`/${lang}#contact`}>{lang === 'en' ? 'Get in touch' : 'Kontakta oss'}</a></li>
          </ul>
        </div>
      </div>
      <div class="footer__bottom">
        <span>¬© {new Date().getFullYear()} Anaxiatech AB ¬Ζ Org.nr 556673-0056</span>
        <span>{lang === 'en' ? 'Crackzβ³Δ is a trademark of Anaxiatech AB' : 'Crackzβ³Δ ΟΛr ett varumΟΛrke som tillhΟΕr Anaxiatech AB'}</span>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.querySelector('.nav__hamburger') as HTMLElement;
    const menu = document.getElementById('mobile-menu') as HTMLElement;
    const closeBtn = menu?.querySelector('.mobile-menu__close') as HTMLElement;

    function openMenu() {
      menu.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    menu?.addEventListener('click', (e) => {
      if (e.target === menu) closeMenu();
    });
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    // Language switcher: set cookie on click
    document.querySelectorAll('.lang-switcher__btn').forEach(el => {
      el.addEventListener('click', () => {
        const chosenLang = (el as HTMLElement).dataset.lang;
        if (chosenLang) {
          document.cookie = `lang=${chosenLang}; path=/; max-age=31536000; SameSite=Lax`;
        }
      });
    });
  </script>
</body>
</html>
