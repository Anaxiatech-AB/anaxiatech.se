---
// Root redirect: default to /en, but honour lang cookie for /sv
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anaxiatech AB</title>
  <link rel="canonical" href="https://anaxiatech.se/en/" />
  <noscript><meta http-equiv="refresh" content="0; url=/en/" /></noscript>
</head>
<body>
  <script>
    const lang = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/)?.[1];
    window.location.replace(lang === 'sv' ? '/sv/' : '/en/');
  </script>
</body>
</html>
